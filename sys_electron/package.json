{
  "name": "music-download-electron",
  "version": "1.0.0",
  "description": "Music Download Platform - Electron Desktop App",
  "main": "dist/main/main.js",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package:linux": "electron-vite build && electron-builder --linux",
    "package:win": "electron-vite build && electron-builder --win"
  },
  "dependencies": {
    "electron": "^33.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.5.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "tailwindcss": "^3.4.19"
  },
  "build": {
    "appId": "com.music-download.app",
    "productName": "音乐下载平台",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../sys_python/dist/music_download_backend",
        "to": "flask-backend/music_download_backend"
      }
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Audio"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
